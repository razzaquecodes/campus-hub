{
  "buildCommand": "npx expo export --platform web --output-dir .expo-output && mkdir -p dist && cp -r .expo-output/* dist/ && cp index.html dist/ && cp manifest.webmanifest dist/app/manifest.webmanifest 2>/dev/null || true && cp sw.js dist/app/sw.js 2>/dev/null || true && for f in dist/app/*.html; do sed -i 's|href=\"/manifest.json\"|href=\"/app/manifest.json\"|g' \"$f\" 2>/dev/null || true; done",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app/"
    },
    {
      "source": "/app/_expo/static/(.*)",
      "destination": "/app/_expo/static/$1"
    },
    {
      "source": "/app/(.*)",
      "destination": "/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/app/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/app/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/app/_expo/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}